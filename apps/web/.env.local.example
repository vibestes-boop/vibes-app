# ──────────────────────────────────────────────────────────────────────────────
# Serlo Web — Environment Variables
#
# Kopiere diese Datei zu `.env.local` und fülle die Werte aus.
# `.env.local` ist in .gitignore — niemals committen.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Site ─────────────────────────────────────────────────────────────────────
# Öffentliche URL dieser Web-App (für OG-Images, Redirects, Sitemap).
# Dev: http://localhost:3000
# Prod: https://serlo.app (oder entsprechende Domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dieselben Keys wie die Native-App — beide nutzen dieselbe Backend-Instanz.
# Projekt-Dashboard: https://supabase.com/dashboard/project/<ID>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-Role-Key — NUR server-side genutzt (niemals NEXT_PUBLIC_*).
# Wird gebraucht für: Edge-Function-Invokes mit Admin-Rechten, Order-Workflows.
SUPABASE_SERVICE_ROLE_KEY=


# ─── LiveKit (Phase 5/6) ──────────────────────────────────────────────────────
# Für Live-Viewer und PC-Streamer-Host.
NEXT_PUBLIC_LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=


# ─── Stripe (Phase 10) ────────────────────────────────────────────────────────
# Coin-Shop im Web läuft über Stripe Checkout (nicht RevenueCat).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Redirect-URLs nach erfolgreichem bzw. abgebrochenem Checkout. {CHECKOUT_SESSION_ID}
# wird von Stripe serverseitig ersetzt, bevor der User redirected wird.
# Diese Werte müssen als Supabase-Edge-Function-Secrets gesetzt werden
# (nicht als NEXT_PUBLIC_*) — sie werden von `create-checkout-session` gelesen.
#   supabase secrets set STRIPE_SUCCESS_URL=https://serlo.app/coin-shop/success?session_id={CHECKOUT_SESSION_ID}
#   supabase secrets set STRIPE_CANCEL_URL=https://serlo.app/coin-shop/cancelled
STRIPE_SUCCESS_URL=http://localhost:3000/coin-shop/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/coin-shop/cancelled


# ─── Sentry ───────────────────────────────────────────────────────────────────
# Gleicher Sentry-Org wie Native; eigenes Projekt für Web.
#
# DSN: `NEXT_PUBLIC_SENTRY_DSN` wird in das Client-Bundle inlined und von
# `sentry.client.config.ts` gelesen. `SENTRY_DSN` ist der Server-only-
# Fallback für `sentry.server.config.ts` / `sentry.edge.config.ts` — in
# 99 % der Setups reicht nur `NEXT_PUBLIC_SENTRY_DSN` (wird automatisch
# als Server-Fallback genutzt). Separates Setzen nur wenn Web-Client und
# Web-Server in unterschiedliche Sentry-Projekte schreiben sollen.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Source-Maps-Upload (nur im CI gesetzt; lokal leer lassen damit der Build
# die Upload-Phase skippt). Token aus:
#   https://sentry.io/settings/account/api/auth-tokens/ — Scope: `project:releases`
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Release-Tag — optional; CI setzt das üblicherweise auf den Git-SHA
# (z.B. `vercel build` injected `VERCEL_GIT_COMMIT_SHA`).
# NEXT_PUBLIC_SENTRY_RELEASE wird in Browser-Bundle inlined.
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_RELEASE=

# Environment-Label (production / preview / staging). Default: NODE_ENV.
# Nützlich wenn Vercel-Preview-Deploys separat getaggt werden sollen.
NEXT_PUBLIC_SENTRY_ENV=
SENTRY_ENV=


# ─── Web-Push (Phase 12 — v1.w.12.4) ─────────────────────────────────────────
# W3C Push-API mit VAPID-Signing. Key-Pair einmalig generieren und dann
# in drei Locations setzen:
#
#   1) NEXT_PUBLIC_VAPID_PUBLIC_KEY   → Client (useWebPush-Hook)
#   2) VAPID_PUBLIC_KEY / _PRIVATE    → Edge-Function `send-web-push`
#                                       (als Supabase-Secret setzen, NICHT
#                                       committen!)
#   3) VAPID_SUBJECT                  → Kontakt-URL für den Push-Service,
#                                       Konvention: `mailto:ops@<domain>`
#
# Generieren:  npx web-push generate-vapid-keys
# Supabase:    supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:ops@serlo.app
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY muss das GLEICHE Pair wie die Edge-Function
# sein — andernfalls schlägt die VAPID-Signatur fehl und der Push-Service
# lehnt ab (403 `vapid_mismatch`).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=


# ─── PostHog ──────────────────────────────────────────────────────────────────
# Privacy-friendly Analytics. EU-Region genutzt für DSGVO.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com


# ─── Cloudflare R2 (Phase 8 — Uploads) ───────────────────────────────────────
# Shared Bucket mit Native. Signed-Upload-URLs werden server-seitig generiert.
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=serlo-videos
CF_R2_PUBLIC_URL=
